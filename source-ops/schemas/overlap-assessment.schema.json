{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "crucix/source-ops/overlap-assessment.schema.json",
  "title": "Crucix Source Overlap Assessment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "candidateId",
    "generatedAt",
    "summary",
    "comparedAgainst",
    "overlap",
    "dimensionScores",
    "weightedTotal",
    "recommendation",
    "promotionReadiness",
    "confidence"
  ],
  "properties": {
    "version": { "type": "string", "const": "source-overlap-v1" },
    "candidateId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1 },
    "comparedAgainst": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "reason"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "category": { "type": ["string", "null"] },
          "operatorRole": { "type": ["string", "null"] }
        }
      }
    },
    "overlap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duplicateSignalRisk", "incrementalCoverage", "likelyOperatorImpact", "likelyLlmUtility"],
      "properties": {
        "duplicateSignalRisk": { "type": "string", "enum": ["low", "medium", "high", "very-high"] },
        "incrementalCoverage": { "type": "string", "enum": ["low", "medium", "high"] },
        "likelyOperatorImpact": { "type": "string", "enum": ["reduces-noise", "neutral", "adds-review-pressure"] },
        "likelyLlmUtility": { "type": "string", "enum": ["low", "medium", "high"] },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "dimensionScores": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "score", "weight", "weightedScore", "reasoning"],
        "properties": {
          "dimension": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 1, "maximum": 5 },
          "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
          "weightedScore": { "type": "number", "minimum": 0, "maximum": 5 },
          "reasoning": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "weightedTotal": { "type": "number", "minimum": 1, "maximum": 5 },
    "recommendation": { "type": "string", "enum": ["research", "grade", "shadow", "reject", "deprecate", "prepare-onboarding"] },
    "promotionReadiness": { "type": "string", "enum": ["not-ready", "research-needed", "shadow-ready", "human-review-required"] },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "blockingIssues": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
